{
  "productName": "Textpad++",
  "version": "0.1.0",
  "identifier": "com.textpad.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Textpad++",
        "label": "main",
        "width": 1200,
        "height": 800,
        "transparent": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/textpad_core"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}