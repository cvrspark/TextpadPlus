{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-stdin-write",
    "dialog:allow-open",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [{ "name": "binaries/textpad_core", "sidecar": true, "args": true }]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [{ "name": "binaries/textpad_core", "sidecar": true, "args": true }]
    }
  ]
}